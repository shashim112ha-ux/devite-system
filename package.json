{
  "name": "devite-control",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "npm run dev --workspace=apps/mobile",
    "dev:server": "npm run dev --workspace=apps/server",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspaces",
    "start:server": "npm start --workspace=apps/server",
    "start:web": "npm start --workspace=apps/web"
  },
  "dependencies": {
    "@tanstack/react-query": "^4.44.0"
  },
  "devDependencies": {
    "ts-morph": "^28.0.0"
  }
}
